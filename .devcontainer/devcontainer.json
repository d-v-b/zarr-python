{
	"name": "zarr-python (Claude Code sandbox)",
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"TZ": "${localEnv:TZ:UTC}",
			"CLAUDE_CODE_VERSION": "latest",
			"GIT_DELTA_VERSION": "0.18.2",
			"ZSH_IN_DOCKER_VERSION": "1.2.0"
		}
	},
	// Capabilities required by init-firewall.sh to install iptables/ipset rules.
	"runArgs": [
		"--cap-add=NET_ADMIN",
		"--cap-add=NET_RAW"
	],
	// init: proper PID 1 (signal handling / zombie reaping).
	"init": true,
	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"charliermarsh.ruff",
				"ms-python.python",
				"ms-python.mypy-type-checker",
				"eamodio.gitlens"
			],
			"settings": {
				"python.defaultInterpreterPath": "/home/node/.venv-zarr/bin/python",
				"python.testing.pytestEnabled": true,
				"python.testing.pytestArgs": [
					"tests"
				],
				"editor.formatOnSave": true,
				"[python]": {
					"editor.defaultFormatter": "charliermarsh.ruff",
					"editor.codeActionsOnSave": {
						"source.organizeImports": "explicit"
					}
				},
				"terminal.integrated.defaultProfile.linux": "zsh",
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "bash",
						"icon": "terminal-bash"
					},
					"zsh": {
						"path": "zsh"
					}
				}
			}
		}
	},
	"remoteUser": "node",
	"workspaceFolder": "/workspace",
	// SECURITY MODEL (threat model: a prompt-injected / runaway skip-permissions
	// agent must not damage the host or exfiltrate secrets):
	//   - NO host bind mounts. The container clones its OWN copy of the repo
	//     (onCreateCommand), so the agent's filesystem cannot reach the host repo,
	//     ~/.ssh, ~/.aws, or the host ~/.gitconfig (which may carry tokens).
	//   - GitHub access is a SEPARATE agent account with a fork-only, fine-grained,
	//     expiring PAT. Authenticate once inside via `gh auth login` (see README);
	//     the token lives only in the container's config volume, never on the host
	//     env. The agent pushes to its fork; you review/merge PRs from your real
	//     account. A leaked token can only touch the agent's forks.
	//   - Egress is default-DENY (init-firewall.sh): even a leaked secret cannot
	//     leave, except to the allowlisted hosts.
	//   - ~/.claude is a fresh container-only volume (separate Claude identity).
	"mounts": [
		"source=zarr-devc-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
		"source=zarr-devc-config-${devcontainerId},target=/home/node/.claude,type=volume",
		"source=zarr-devc-ghconfig-${devcontainerId},target=/home/node/.config/gh,type=volume"
	],
	"containerEnv": {
		"NODE_OPTIONS": "--max-old-space-size=4096",
		"CLAUDE_CONFIG_DIR": "/home/node/.claude",
		"POWERLEVEL9K_DISABLE_GITSTATUS": "true",
		// Which fork + branch the container clones. Point REPO_URL at the AGENT
		// account's fork, not your canonical repo.
		"ZARR_REPO_URL": "https://github.com/CHANGE-ME-agent-account/zarr-python.git",
		"ZARR_BRANCH": "main",
		// Git identity for the agent's commits, supplied WITHOUT mounting the host
		// ~/.gitconfig (which may contain credential helpers / embedded tokens).
		"GIT_AUTHOR_NAME": "zarr agent",
		"GIT_AUTHOR_EMAIL": "agent@example.invalid",
		"GIT_COMMITTER_NAME": "zarr agent",
		"GIT_COMMITTER_EMAIL": "agent@example.invalid",
		// Build the project venv OUTSIDE the cloned /workspace.
		"UV_PROJECT_ENVIRONMENT": "/home/node/.venv-zarr",
		"UV_LINK_MODE": "copy",
		// A shallow clone may lack the tag history hatch-vcs needs; pin so the
		// editable build is deterministic. Only zarr is built here, so the generic
		// key (the dist-scoped form is not honored under uv's isolated build) is safe.
		"SETUPTOOLS_SCM_PRETEND_VERSION": "3.2.2.dev0",
		// Supply-chain hardening defaults.
		"NPM_CONFIG_IGNORE_SCRIPTS": "true",
		"NPM_CONFIG_FUND": "false",
		"NPM_CONFIG_UPDATE_NOTIFIER": "false",
		"PYTHONDONTWRITEBYTECODE": "1",
		"PIP_DISABLE_PIP_VERSION_CHECK": "1"
	},
	// Clone the agent fork into the (pre-created, node-owned) workspace. Runs
	// during creation while the network is open, before the firewall. The guard
	// makes re-runs a no-op. Uses gh auth if you logged in; for a public fork the
	// anonymous clone also works.
	"onCreateCommand": "if [ ! -d /workspace/.git ]; then git clone --branch \"$ZARR_BRANCH\" \"$ZARR_REPO_URL\" /workspace; fi",
	// Install the project + dev tooling and the prek git hooks.
	// Install deps + tooling + hooks, and register gh as git's credential helper
	// for github.com. Set declaratively (not via `gh auth setup-git`, which needs
	// gh already authenticated): it takes effect as soon as you `gh auth login`,
	// so the agent's `git push` over HTTPS transparently uses gh's token.
	"postCreateCommand": "uv sync --group dev && uv tool install prek && prek install && git config --global credential.\"https://github.com\".helper '!gh auth git-credential'",
	// Lock down outbound network before the environment is used.
	"postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
	"waitFor": "postStartCommand"
}
